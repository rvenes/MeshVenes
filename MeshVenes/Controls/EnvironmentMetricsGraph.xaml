<UserControl
    x:Class="MeshVenes.Controls.EnvironmentMetricsGraph"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="*,Auto">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto">
            <Grid Margin="0,6,8,6"
                  RowDefinitions="Auto,*,Auto"
                  MinWidth="52">
                <TextBlock x:Name="TemperatureAxisTopText"
                           Text="—"
                           Foreground="#FF4FC3F7"
                           FontSize="10"
                           FontFamily="Consolas"
                           HorizontalAlignment="Right"/>
                <TextBlock x:Name="TemperatureAxisMidText"
                           Grid.Row="1"
                           Text="—"
                           Foreground="#FF4FC3F7"
                           FontSize="10"
                           FontFamily="Consolas"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TemperatureAxisBottomText"
                           Grid.Row="2"
                           Text="—"
                           Foreground="#FF4FC3F7"
                           FontSize="10"
                           FontFamily="Consolas"
                           HorizontalAlignment="Right"/>
            </Grid>

            <Grid Grid.Column="1"
                  x:Name="PlotHost"
                  Background="{ThemeResource CardBackgroundFillColorDefault}"
                  PointerMoved="PlotHost_PointerMoved"
                  PointerExited="PlotHost_PointerExited">
                <Canvas x:Name="GridCanvas"
                        IsHitTestVisible="False"/>
                <Canvas x:Name="ChartCanvas"
                        Background="Transparent">
                    <Polyline x:Name="TemperatureLine"
                              Stroke="#FF4FC3F7"
                              StrokeThickness="2.2"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"/>
                    <Polyline x:Name="HumidityLine"
                              Stroke="#FF81C784"
                              StrokeThickness="2"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"/>
                    <Polyline x:Name="PressureLine"
                              Stroke="#FFFFB74D"
                              StrokeThickness="2"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"/>
                </Canvas>
                <Canvas x:Name="OverlayCanvas"
                        IsHitTestVisible="False">
                    <Line x:Name="SelectionVerticalLine"
                          Stroke="#AA8AA0C8"
                          StrokeThickness="1.2"
                          StrokeDashArray="3,4"
                          Visibility="Collapsed"/>
                    <Ellipse x:Name="TemperatureMarker"
                             Width="10"
                             Height="10"
                             Fill="#FF4FC3F7"
                             Stroke="#CCFFFFFF"
                             StrokeThickness="1.5"
                             Visibility="Collapsed"/>
                    <Ellipse x:Name="HumidityMarker"
                             Width="9"
                             Height="9"
                             Fill="#FF81C784"
                             Stroke="#CCFFFFFF"
                             StrokeThickness="1.4"
                             Visibility="Collapsed"/>
                    <Ellipse x:Name="PressureMarker"
                             Width="9"
                             Height="9"
                             Fill="#FFFFB74D"
                             Stroke="#CCFFFFFF"
                             StrokeThickness="1.4"
                             Visibility="Collapsed"/>
                    <Border x:Name="SelectionTooltip"
                            Visibility="Collapsed"
                            Background="{ThemeResource CardBackgroundFillColorDefault}"
                            BorderBrush="{ThemeResource CardStrokeColorDefault}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10"
                            MaxWidth="320">
                        <StackPanel Spacing="3">
                            <TextBlock x:Name="SelectionTooltipTime"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                            <TextBlock x:Name="SelectionTooltipTemperature"
                                       FontSize="13"
                                       Foreground="#FF4FC3F7"/>
                            <TextBlock x:Name="SelectionTooltipHumidity"
                                       FontSize="13"
                                       Foreground="#FF81C784"/>
                            <TextBlock x:Name="SelectionTooltipPressure"
                                       FontSize="13"
                                       Foreground="#FFFFB74D"/>
                        </StackPanel>
                    </Border>
                </Canvas>
            </Grid>

            <Grid Grid.Column="2"
                  Margin="8,6,0,6"
                  RowDefinitions="Auto,*,Auto"
                  MinWidth="48">
                <TextBlock x:Name="HumidityAxisTopText"
                           Text="—"
                           Foreground="#FF81C784"
                           FontSize="10"
                           FontFamily="Consolas"
                           HorizontalAlignment="Left"/>
                <TextBlock x:Name="HumidityAxisMidText"
                           Grid.Row="1"
                           Text="—"
                           Foreground="#FF81C784"
                           FontSize="10"
                           FontFamily="Consolas"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="HumidityAxisBottomText"
                           Grid.Row="2"
                           Text="—"
                           Foreground="#FF81C784"
                           FontSize="10"
                           FontFamily="Consolas"
                           HorizontalAlignment="Left"/>
            </Grid>

            <Grid Grid.Column="3"
                  Margin="4,6,0,6"
                  RowDefinitions="Auto,*,Auto"
                  MinWidth="56">
                <TextBlock x:Name="PressureAxisTopText"
                           Text="—"
                           Foreground="#FFFFB74D"
                           FontSize="10"
                           FontFamily="Consolas"
                           HorizontalAlignment="Left"/>
                <TextBlock x:Name="PressureAxisMidText"
                           Grid.Row="1"
                           Text="—"
                           Foreground="#FFFFB74D"
                           FontSize="10"
                           FontFamily="Consolas"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="PressureAxisBottomText"
                           Grid.Row="2"
                           Text="—"
                           Foreground="#FFFFB74D"
                           FontSize="10"
                           FontFamily="Consolas"
                           HorizontalAlignment="Left"/>
            </Grid>
        </Grid>

        <Grid Grid.Row="1"
              Margin="60,6,106,0"
              ColumnDefinitions="Auto,*,Auto"
              MinHeight="20">
            <TextBlock x:Name="AxisStartText"
                       Text="—"
                       Opacity="0.8"
                       FontSize="11"
                       FontFamily="Consolas"
                       HorizontalAlignment="Left"/>
            <TextBlock x:Name="AxisMidText"
                       Grid.Column="1"
                       Text="—"
                       Opacity="0.75"
                       FontSize="11"
                       FontFamily="Consolas"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="AxisEndText"
                       Grid.Column="2"
                       Text="—"
                       Opacity="0.8"
                       FontSize="11"
                       FontFamily="Consolas"
                       HorizontalAlignment="Right"/>
        </Grid>
    </Grid>
</UserControl>
