<Page
    x:Class="MeshVenes.Pages.NodesPage"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MeshVenes.Models"
    xmlns:pages="using:MeshVenes.Pages"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:localcontrols="using:MeshVenes.Controls">

    <Page.Resources>
        <CollectionViewSource x:Name="NodesView" x:Key="NodesView"/>
        <Style x:Key="CopyableTextBlockStyle" TargetType="TextBlock">
            <Setter Property="ContextFlyout">
                <Setter.Value>
                    <MenuFlyout Opening="TextCopyFlyout_Opening">
                        <MenuFlyoutItem Text="Copy" Click="CopyTextBlockMenuItem_Click"/>
                    </MenuFlyout>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryTabHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Page.Resources>

    <Grid Padding="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT -->
        <Grid Grid.Column="0" RowDefinitions="Auto,6,Auto,6,Auto,6,*">
            <TextBlock Text="Nodes" FontSize="22" FontWeight="SemiBold" />

            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Opacity="0.85" VerticalAlignment="Center">
                <TextBlock Text="{x:Bind NodeCountsText, Mode=OneWay}"/>
                <Button Content="Sort / Filter">
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedLeft">
                            <ScrollViewer MaxHeight="420" Width="280">
                                <StackPanel Padding="12" Spacing="10">
                                    <TextBlock Text="Sort by" FontWeight="SemiBold"/>
                                    <RadioButton Content="Alphabetical"
                                                 GroupName="NodesSortMode"
                                                 Tag="Alphabetical"
                                                 IsChecked="{x:Bind IsSortByAlphabetical, Mode=OneWay}"
                                                 Checked="SortModeRadio_Checked"/>
                                    <RadioButton Content="Hops away"
                                                 GroupName="NodesSortMode"
                                                 Tag="HopsAway"
                                                 IsChecked="{x:Bind IsSortByHopsAway, Mode=OneWay}"
                                                 Checked="SortModeRadio_Checked"/>
                                    <RadioButton Content="Last heard"
                                                 GroupName="NodesSortMode"
                                                 Tag="LastHeard"
                                                 IsChecked="{x:Bind IsSortByLastHeard, Mode=OneWay}"
                                                 Checked="SortModeRadio_Checked"/>
                                    <RadioButton Content="Favorites"
                                                 GroupName="NodesSortMode"
                                                 Tag="FavoritesFirst"
                                                 IsChecked="{x:Bind IsSortByFavorites, Mode=OneWay}"
                                                 Checked="SortModeRadio_Checked"/>
                                    <RadioButton Content="My Nodes"
                                                 GroupName="NodesSortMode"
                                                 Tag="MyNodes"
                                                 IsChecked="{x:Bind IsSortByMyNodes, Mode=OneWay}"
                                                 Checked="SortModeRadio_Checked"/>

                                    <TextBlock Text="Order" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                    <RadioButton Content="Ascending"
                                                 GroupName="NodesSortDirection"
                                                 Tag="Ascending"
                                                 IsChecked="{x:Bind IsSortAscending, Mode=OneWay}"
                                                 Checked="SortDirectionRadio_Checked"/>
                                    <RadioButton Content="Descending"
                                                 GroupName="NodesSortDirection"
                                                 Tag="Descending"
                                                 IsChecked="{x:Bind IsSortDescending, Mode=OneWay}"
                                                 Checked="SortDirectionRadio_Checked"/>

                                    <TextBlock Text="Filters" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                    <CheckBox Content="Hide inactive"
                                              Tag="HideInactive"
                                              IsChecked="{x:Bind IsHideInactiveEnabled, Mode=OneWay}"
                                              Click="FilterOption_Click"/>
                                    <CheckBox Content="My Nodes"
                                              Tag="MyNodesOnly"
                                              IsChecked="{x:Bind IsMyNodesFilterEnabled, Mode=OneWay}"
                                              Click="FilterOption_Click"/>
                                    <CheckBox Content="Favorites"
                                              Tag="FavoritesOnly"
                                              IsChecked="{x:Bind IsFavoritesFilterEnabled, Mode=OneWay}"
                                              Click="FilterOption_Click"/>
                                    <CheckBox Content="Via LoRa"
                                              Tag="IncludeLoRa"
                                              IsChecked="{x:Bind IsLoRaFilterEnabled, Mode=OneWay}"
                                              Click="FilterOption_Click"/>
                                    <CheckBox Content="Via MQTT"
                                              Tag="IncludeMqtt"
                                              IsChecked="{x:Bind IsMqttFilterEnabled, Mode=OneWay}"
                                              Click="FilterOption_Click"/>
                                    <Button Content="Clear filters"
                                            HorizontalAlignment="Left"
                                            Margin="0,6,0,0"
                                            Visibility="{x:Bind ActiveNodeFiltersVisibility, Mode=OneWay}"
                                            Click="ClearFilters_Click"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <TextBlock Text="{x:Bind ActiveNodeFiltersText, Mode=OneWay}"
                           Visibility="{x:Bind ActiveNodeFiltersVisibility, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="145"/>
            </StackPanel>

            <TextBox Grid.Row="4"
                     x:Name="SearchBox"
                     PlaceholderText="Search (name / id)"
                     TextChanged="SearchBox_TextChanged"/>

            <ListView Grid.Row="6"
                      x:Name="NodesList"
                      ItemsSource="{Binding Source={StaticResource NodesView}}"
                      SelectionMode="Single"
                      SelectionChanged="NodesList_SelectionChanged"
                      DoubleTapped="NodesList_DoubleTapped">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:NodeLive">
                        <Grid Padding="6" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto"
                              Visibility="{x:Bind NodeVisibility}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="4" Margin="0,0,8,0">
                                <Ellipse Width="8" Height="8"
                                         Fill="LimeGreen"
                                         VerticalAlignment="Center"
                                         Visibility="{x:Bind LogIndicatorVisible}"/>
                                <Ellipse Width="8" Height="8"
                                         Fill="LimeGreen"
                                         VerticalAlignment="Center"
                                         Visibility="{x:Bind UnreadVisible}"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{x:Bind ShortId}" Opacity="0.7" VerticalAlignment="Center"/>

                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8" Opacity="0.8" Margin="0,2,0,0">
                                <TextBlock Text="{x:Bind LastHeard}" />
                                <TextBlock Text="Link:"/>
                                <TextBlock Text="{x:Bind TransportBadgeText}" Foreground="{x:Bind TransportBrush}" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind HopsBadgeText}" />
                            </StackPanel>

                            <Button Grid.Row="1"
                                    Grid.Column="2"
                                    Content="{x:Bind FavoriteGlyph, Mode=OneWay}"
                                    Foreground="{x:Bind FavoriteBrush, Mode=OneWay}"
                                    Click="NodeFavoriteButton_Click"
                                    FontSize="16"
                                    Padding="4,0"
                                    MinWidth="26"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    ToolTipService.ToolTip="Favorite node (stored on connected node)"/>

                            <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8" Opacity="0.75" Margin="0,2,0,0">
                                <TextBlock Text="🗒"/>
                                <TextBlock Text="📍" Visibility="{x:Bind PositionIconVisibility}"/>
                                <TextBlock Text="⛔"
                                           Visibility="{x:Bind UnmonitoredVisibility}"
                                           Foreground="{x:Bind UnmonitoredBrush}"
                                           ToolTipService.ToolTip="Unmonitored node"/>
                                <TextBlock Text="{x:Bind DistanceDirectionText}" Visibility="{x:Bind DistanceDirectionVisibility}" Foreground="#FF7CB8FF"/>
                                <TextBlock Text="{x:Bind BatteryBadgeText}"
                                           Foreground="{x:Bind BatteryBadgeBrush}"
                                           Visibility="{x:Bind BatteryBadgeVisibility}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- RIGHT -->
        <Grid Grid.Column="2" RowDefinitions="Auto,8,*,Auto">
            <!-- More height here: info + buttons fit without covering the position text. -->
            <Border CornerRadius="10" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefault}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <Grid Grid.Column="0" RowDefinitions="Auto,8,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource CopyableTextBlockStyle}"
                                       Text="{x:Bind SelectedTitle, Mode=OneWay}"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>
                            <Button Content="Open current position"
                                    Click="OpenCurrentPosition_Click"
                                    IsEnabled="{x:Bind HasSelectedPosition, Mode=OneWay}"/>
                            <ToggleButton Content="My Node"
                                          Click="MyNodeToggle_Click"
                                          IsChecked="{x:Bind IsSelectedMyNode, Mode=OneWay}"
                                          IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  VerticalScrollMode="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  HorizontalScrollMode="Disabled"
                                  MaxHeight="240">
                        <Grid ColumnDefinitions="*,16,*">
                            <Grid Grid.Column="0"
                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                                  ColumnDefinitions="Auto,*"
                                  ColumnSpacing="10"
                                  RowSpacing="4">
                                <TextBlock Style="{StaticResource CopyableTextBlockStyle}" Text="Node number:" Opacity="0.75"/>
                                <TextBlock Style="{StaticResource CopyableTextBlockStyle}" Grid.Column="1" Text="{x:Bind SelectedNodeNumText, Mode=OneWay}" TextWrapping="Wrap"/>

                                <TextBlock Style="{StaticResource CopyableTextBlockStyle}" Grid.Row="1" Text="Last heard:" Opacity="0.75"/>
                                <TextBlock Style="{StaticResource CopyableTextBlockStyle}" Grid.Row="1" Grid.Column="1" Text="{x:Bind SelectedLastHeardText, Mode=OneWay}" TextWrapping="Wrap"/>

                                <TextBlock Style="{StaticResource CopyableTextBlockStyle}" Grid.Row="2" Text="User ID / name:" Opacity="0.75"/>
                                <TextBlock Style="{StaticResource CopyableTextBlockStyle}" Grid.Row="2" Grid.Column="1" Text="{x:Bind SelectedUserIdText, Mode=OneWay}" TextWrapping="Wrap"/>

                                <TextBlock Style="{StaticResource CopyableTextBlockStyle}" Grid.Row="3" Text="Uptime:" Opacity="0.75"/>
                                <TextBlock Style="{StaticResource CopyableTextBlockStyle}" Grid.Row="3" Grid.Column="1" Text="{x:Bind SelectedUptimeText, Mode=OneWay}" TextWrapping="Wrap"/>

                                <TextBlock Style="{StaticResource CopyableTextBlockStyle}" Grid.Row="4" Text="First heard:" Opacity="0.75"/>
                                <TextBlock Style="{StaticResource CopyableTextBlockStyle}" Grid.Row="4" Grid.Column="1" Text="{x:Bind SelectedFirstHeardText, Mode=OneWay}" TextWrapping="Wrap"/>

                                <TextBlock Style="{StaticResource CopyableTextBlockStyle}" Grid.Row="5" Text="Signal:" Opacity="0.75"/>
                                <TextBlock Style="{StaticResource CopyableTextBlockStyle}"
                                           Grid.Row="5"
                                           Grid.Column="1"
                                           Text="{x:Bind SelectedSignalDetailsText, Mode=OneWay}"
                                           Foreground="{x:Bind SelectedSignalBrush, Mode=OneWay}"
                                           TextWrapping="Wrap"
                                           FontSize="12"/>
                            </Grid>

                            <Grid Grid.Column="2"
                                  RowDefinitions="Auto,Auto,Auto,Auto"
                                  RowSpacing="8">
                                <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <TextBlock Style="{StaticResource CopyableTextBlockStyle}" Text="Hardware model:" Opacity="0.75"/>
                                    <TextBlock Style="{StaticResource CopyableTextBlockStyle}" Grid.Column="1" Text="{x:Bind SelectedHardwareModelText, Mode=OneWay}" TextWrapping="Wrap"/>
                                </Grid>

                                <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <TextBlock Style="{StaticResource CopyableTextBlockStyle}" Text="Role:" Opacity="0.75"/>
                                    <TextBlock Style="{StaticResource CopyableTextBlockStyle}" Grid.Column="1" Text="{x:Bind SelectedRoleText, Mode=OneWay}" TextWrapping="Wrap"/>
                                </Grid>

                                <Grid Grid.Row="2" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <TextBlock Style="{StaticResource CopyableTextBlockStyle}" Text="Firmware version:" Opacity="0.75"/>
                                    <TextBlock Style="{StaticResource CopyableTextBlockStyle}" Grid.Column="1" Text="{x:Bind SelectedFirmwareVersionText, Mode=OneWay}" TextWrapping="Wrap"/>
                                </Grid>

                                <Grid Grid.Row="3" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <TextBlock Style="{StaticResource CopyableTextBlockStyle}" Text="Public key:" Opacity="0.75"/>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Style="{StaticResource CopyableTextBlockStyle}"
                                                   Text="{x:Bind SelectedPublicKeyDisplayText, Mode=OneWay}"
                                                   TextWrapping="Wrap"
                                                   FontFamily="Consolas"
                                                   FontSize="12"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Button Content="{x:Bind PublicKeyToggleButtonText, Mode=OneWay}"
                                                    Click="TogglePublicKeyVisibility_Click"
                                                    IsEnabled="{x:Bind HasSelectedPublicKey, Mode=OneWay}"/>
                                            <Button Content="Copy"
                                                    Click="CopySelectedPublicKey_Click"
                                                    IsEnabled="{x:Bind HasSelectedPublicKey, Mode=OneWay}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Grid>
                        </ScrollViewer>
                    </Grid>

                    <StackPanel Grid.Column="1"
                                Spacing="8"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                        <Button Content="Send DM"
                                Click="SendDm_Click"
                                IsEnabled="{x:Bind HasSelection, Mode=OneWay}"
                                HorizontalAlignment="Right"/>
                        <Button Content="{x:Bind TraceRouteButtonText, Mode=OneWay}"
                                Click="TraceRoute_Click"
                                IsEnabled="{x:Bind IsTraceRouteEnabled, Mode=OneWay}"
                                HorizontalAlignment="Right"/>
                        <Button Content="Exchange User Info"
                                Click="ExchangeUserInfo_Click"
                                IsEnabled="{x:Bind HasSelection, Mode=OneWay}"
                                HorizontalAlignment="Right"/>
                        <Button Content="Exchange Positions"
                                Click="ExchangePositions_Click"
                                IsEnabled="{x:Bind HasSelection, Mode=OneWay}"
                                HorizontalAlignment="Right"/>
                        <Button Content="{x:Bind IgnoreNodeButtonText, Mode=OneWay}"
                                Click="IgnoreNode_Click"
                                Visibility="{x:Bind IgnoreDeleteActionsVisibility, Mode=OneWay}"
                                IsEnabled="{x:Bind CanEditSelectedNodeState, Mode=OneWay}"
                                HorizontalAlignment="Right"/>
                        <Button Content="Delete Node"
                                Click="DeleteNode_Click"
                                Visibility="{x:Bind IgnoreDeleteActionsVisibility, Mode=OneWay}"
                                IsEnabled="{x:Bind CanEditSelectedNodeState, Mode=OneWay}"
                                HorizontalAlignment="Right"/>
                        <Button Content="Refresh device metadata"
                                Click="RefreshDeviceMetadata_Click"
                                Visibility="{x:Bind ConnectedNodeActionsVisibility, Mode=OneWay}"
                                IsEnabled="{x:Bind CanRunConnectedNodeActions, Mode=OneWay}"
                                HorizontalAlignment="Right"/>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Right"
                                    Visibility="{x:Bind ConnectedNodeActionsVisibility, Mode=OneWay}">
                            <Button Content="Power Off"
                                    Click="PowerOffNode_Click"
                                    IsEnabled="{x:Bind CanRunConnectedNodeActions, Mode=OneWay}"/>
                            <Button Content="Reboot"
                                    Click="RebootNode_Click"
                                    IsEnabled="{x:Bind CanRunConnectedNodeActions, Mode=OneWay}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    CornerRadius="10"
                    Background="{ThemeResource CardBackgroundFillColorDefault}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <controls:TabView x:Name="DetailsTabs"
                                  IsAddTabButtonVisible="False"
                                  TabWidthMode="SizeToContent"
                                  SelectionChanged="DetailsTabs_SelectionChanged"
                                  HorizontalContentAlignment="Stretch"
                                  VerticalContentAlignment="Stretch"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                    <controls:TabViewItem x:Name="MapTabItem" IsClosable="False">
                        <controls:TabViewItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:Name="MapTabHeaderText" Text="Map" Style="{StaticResource PrimaryTabHeaderTextStyle}"/>
                            </StackPanel>
                        </controls:TabViewItem.Header>
                        <Border CornerRadius="10"
                                Background="{ThemeResource CardBackgroundFillColorDefault}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch">
                            <Grid RowDefinitions="Auto,8,*"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Left"
                                            Spacing="8"
                                            Margin="0,8,0,0">
                                    <Button Content="{x:Bind GpsTrackButtonText, Mode=OneWay}" Click="ToggleGpsTrack_Click" IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                    <Button Content="Zoom" Click="ZoomToNode_Click" IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                    <Button Content="Fit" Click="FitAll_Click"/>
                                    <Button Content="Reset map" Click="ResetMap_Click"/>
                                </StackPanel>
                                <controls:WebView2 x:Name="MapView"
                                                   Grid.Row="2"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Stretch"
                                                   MinHeight="300"/>
                            </Grid>
                        </Border>
                    </controls:TabViewItem>

                    <controls:TabViewItem x:Name="DeviceMetricsTabItem" IsClosable="False">
                        <controls:TabViewItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:Name="DeviceMetricsTabHeaderText" Text="Device Metrics" Style="{StaticResource PrimaryTabHeaderTextStyle}"/>
                                <Ellipse Width="8" Height="8" Fill="LimeGreen" VerticalAlignment="Center"
                                         Visibility="{x:Bind DeviceMetricsTabIndicatorVisibility, Mode=OneWay}"/>
                            </StackPanel>
                        </controls:TabViewItem.Header>
                        <Grid RowDefinitions="Auto,*" Padding="12">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind DeviceMetricsCountText, Mode=OneWay}" FontWeight="SemiBold"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <Button Content="Show folder"
                                            Tag="DeviceMetrics"
                                            Click="ShowLogFolder_Click"
                                            IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                    <TextBlock Text="Delete older than (days):" VerticalAlignment="Center"/>
                                    <controls:NumberBox Width="96"
                                                        Value="{x:Bind PositionLogRetentionDaysValue, Mode=TwoWay}"
                                                        Minimum="1"
                                                        SpinButtonPlacementMode="Inline"/>
                                    <Button Content="Delete"
                                            Tag="DeviceMetrics"
                                            Click="DeleteLogOlder_Click"
                                            IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                    <Button Content="Delete all"
                                            Tag="DeviceMetrics"
                                            Click="DeleteLogAll_Click"
                                            IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                    <Button Content="Export..."
                                            Click="SaveDeviceMetrics_Click"
                                            IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                </StackPanel>
                            </Grid>
                            <ListView Grid.Row="1"
                                      x:Name="DeviceMetricsLogList"
                                      ItemsSource="{Binding DeviceMetricSamples, ElementName=Root}"
                                      SelectionMode="Single"
                                      SelectionChanged="DeviceMetricsLogList_SelectionChanged"
                                      IsItemClickEnabled="True"
                                      ItemClick="DeviceMetricsLogList_ItemClick"
                                      Margin="0,8,0,0">
                                <ListView.Header>
                                    <StackPanel Spacing="8" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Ellipse Width="8" Height="8" Fill="#FF4CAF50"/>
                                                <TextBlock Text="Battery"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Ellipse Width="8" Height="8" Fill="#FF2196F3"/>
                                                <TextBlock Text="Channel Utilization"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Ellipse Width="8" Height="8" Fill="#FFFF9800"/>
                                                <TextBlock Text="Airtime"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <localcontrols:DeviceMetricsGraph x:Name="DeviceMetricsGraph"
                                                                          Height="220"/>
                                    </StackPanel>
                                </ListView.Header>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="MinHeight" Value="22"/>
                                        <Setter Property="Padding" Value="2"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="190,170,170,170,70"
                                              ColumnSpacing="12"
                                              Padding="2">
                                            <TextBlock Text="{Binding TimestampText}" FontFamily="Consolas" FontSize="12"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding BatteryDisplay}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       Foreground="#FF4CAF50"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ChannelUtilizationDisplay}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       Foreground="#FF2196F3"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding AirtimeDisplay}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       Foreground="#FFFF9800"/>
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding PoweredDisplay}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       Foreground="OrangeRed"
                                                       FontWeight="SemiBold"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </controls:TabViewItem>

                    <controls:TabViewItem x:Name="PositionLogTabItem" IsClosable="False">
                        <controls:TabViewItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:Name="PositionLogTabHeaderText" Text="Position Log" Style="{StaticResource PrimaryTabHeaderTextStyle}"/>
                                <Ellipse Width="8" Height="8" Fill="LimeGreen" VerticalAlignment="Center"
                                         Visibility="{x:Bind PositionTabIndicatorVisibility, Mode=OneWay}"/>
                            </StackPanel>
                        </controls:TabViewItem.Header>
                        <Grid RowDefinitions="Auto,*" Padding="12">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind PositionLogCountText, Mode=OneWay}" FontWeight="SemiBold"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button Content="Show folder"
                                            Tag="Position"
                                            Click="ShowLogFolder_Click"
                                            IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                    <TextBlock Text="Delete older than (days):" VerticalAlignment="Center"/>
                                    <controls:NumberBox Width="96"
                                                        Value="{x:Bind PositionLogRetentionDaysValue, Mode=TwoWay}"
                                                        Minimum="1"
                                                        SpinButtonPlacementMode="Inline"/>
                                    <Button Content="Delete"
                                            Tag="Position"
                                            Click="DeleteLogOlder_Click"
                                            IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                    <Button Content="Delete all"
                                            Tag="Position"
                                            Click="DeleteLogAll_Click"
                                            IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                    <Button Content="Export..."
                                            Click="ExportPositionLog_Click"
                                            IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                </StackPanel>
                            </Grid>
                            <ListView Grid.Row="1"
                                      x:Name="PositionLogList"
                                      ItemsSource="{x:Bind PositionLogEntries, Mode=OneWay}"
                                      SelectionMode="Single"
                                      SelectionChanged="PositionLogList_SelectionChanged"
                                      IsItemClickEnabled="True"
                                      ItemClick="PositionLogList_ItemClick">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="190,280,120,180"
                                              ColumnSpacing="12"
                                              Padding="2"
                                              IsRightTapEnabled="True"
                                              RightTapped="PositionLogEntry_RightTapped">
                                            <Grid.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="Open position in Google Maps"
                                                                    Click="PositionLogOpenMaps_Click"
                                                                    CommandParameter="{Binding}"
                                                                    IsEnabled="{Binding HasValidPosition}"/>
                                                </MenuFlyout>
                                            </Grid.ContextFlyout>
                                            <TextBlock Text="{Binding TimestampText}"
                                                       TextWrapping="NoWrap"
                                                       FontFamily="Consolas"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding CoordinatesDisplay}"
                                                       TextWrapping="NoWrap"
                                                       FontFamily="Consolas"
                                                       Foreground="#FF64B5F6"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AltitudeDisplay}"
                                                       TextWrapping="NoWrap"
                                                       FontFamily="Consolas"
                                                       Foreground="#FFFFB74D"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding SourceDisplay}"
                                                       TextWrapping="NoWrap"
                                                       FontFamily="Consolas"
                                                       Foreground="#FF81C784"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </controls:TabViewItem>

                    <controls:TabViewItem x:Name="TraceRouteTabItem" IsClosable="False">
                        <controls:TabViewItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:Name="TraceRouteTabHeaderText" Text="Trace Route Log" Style="{StaticResource PrimaryTabHeaderTextStyle}"/>
                                <Ellipse Width="8" Height="8" Fill="LimeGreen" VerticalAlignment="Center"
                                         Visibility="{x:Bind TraceRouteTabIndicatorVisibility, Mode=OneWay}"/>
                            </StackPanel>
                        </controls:TabViewItem.Header>
                        <Grid RowDefinitions="Auto,*" Padding="12">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind TraceRouteLogCountText, Mode=OneWay}" FontWeight="SemiBold"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button Content="Show folder"
                                            Tag="TraceRoute"
                                            Click="ShowLogFolder_Click"
                                            IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                    <TextBlock Text="Delete older than (days):" VerticalAlignment="Center"/>
                                    <controls:NumberBox Width="96"
                                                        Value="{x:Bind PositionLogRetentionDaysValue, Mode=TwoWay}"
                                                        Minimum="1"
                                                        SpinButtonPlacementMode="Inline"/>
                                    <Button Content="Delete"
                                            Tag="TraceRoute"
                                            Click="DeleteLogOlder_Click"
                                            IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                    <Button Content="Delete all"
                                            Tag="TraceRoute"
                                            Click="DeleteLogAll_Click"
                                            IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                    <Button Content="Export..." IsEnabled="False"/>
                                </StackPanel>
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,8,0,0">
                                <ListView x:Name="TraceRouteLogList"
                                          ItemsSource="{x:Bind TraceRouteLogEntries, Mode=OneWay}"
                                          SelectionMode="None"
                                          IsItemClickEnabled="False"
                                          PointerWheelChanged="TraceRouteLogList_PointerWheelChanged"
                                          ScrollViewer.HorizontalScrollBarVisibility="Visible"
                                          ScrollViewer.HorizontalScrollMode="Enabled"
                                          ScrollViewer.IsHorizontalRailEnabled="True"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="VerticalContentAlignment" Value="Top"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="pages:TraceRouteLogEntry">
                                            <Border Padding="8" Margin="0,0,0,6"
                                                    BorderThickness="1"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefault}"
                                                    CornerRadius="6"
                                                    HorizontalAlignment="Left">
                                                <StackPanel Spacing="6" Width="{x:Bind RouteContentWidth}">
                                                    <Button Background="Transparent"
                                                            BorderThickness="0"
                                                            Padding="0"
                                                            HorizontalContentAlignment="Left"
                                                            HorizontalAlignment="Stretch"
                                                            Tag="{x:Bind}"
                                                            Click="TraceRouteHeader_Click"
                                                            ToolTipService.ToolTip="Open detailed route dialog">
                                                        <TextBlock Text="{x:Bind HeaderText}"
                                                                   FontFamily="Consolas"
                                                                   Foreground="{x:Bind HeaderBrush}"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="NoWrap"/>
                                                    </Button>
                                                    <StackPanel Spacing="6" HorizontalAlignment="Left">
                                                            <Grid ColumnDefinitions="56,Auto">
                                                                <TextBlock Text="FWD"
                                                                           FontFamily="Consolas"
                                                                           Foreground="{x:Bind PathBrush}"
                                                                           FontWeight="SemiBold"/>
                                                                <ItemsControl Grid.Column="1" ItemsSource="{x:Bind ForwardDisplayNodes}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <StackPanel Orientation="Horizontal"/>
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="pages:RouteDisplayNode">
                                                                            <Button Width="185"
                                                                                    Margin="0,0,10,0"
                                                                                    Padding="0"
                                                                                    Background="Transparent"
                                                                                    BorderThickness="0"
                                                                                    HorizontalContentAlignment="Left"
                                                                                    Click="TraceRouteNodeInfo_Click"
                                                                                    Tag="{x:Bind}">
                                                                                <TextBlock Text="{x:Bind DisplayName}"
                                                                                           FontFamily="Consolas"
                                                                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                                                           TextTrimming="CharacterEllipsis"
                                                                                           ToolTipService.ToolTip="{x:Bind TooltipText}"/>
                                                                            </Button>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </Grid>
                                                            <Grid ColumnDefinitions="56,Auto" Visibility="{x:Bind MetricsVisibility}">
                                                                <TextBlock Text=" "
                                                                           FontFamily="Consolas"/>
                                                                <ItemsControl Grid.Column="1" ItemsSource="{x:Bind ForwardDisplaySegments}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <StackPanel Orientation="Horizontal"/>
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="pages:RouteDisplaySegment">
                                                                            <StackPanel Width="185"
                                                                                        Margin="0,0,10,0"
                                                                                        Orientation="Horizontal"
                                                                                        Spacing="10"
                                                                                        ToolTipService.ToolTip="{x:Bind TooltipText}">
                                                                                <TextBlock Text="{x:Bind DistanceText}"
                                                                                           FontFamily="Consolas"
                                                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                                           TextTrimming="CharacterEllipsis"/>
                                                                                <TextBlock Text="{x:Bind SnrText}"
                                                                                           FontFamily="Consolas"
                                                                                           Foreground="{x:Bind SnrBrush}"
                                                                                           TextTrimming="CharacterEllipsis"/>
                                                                            </StackPanel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </Grid>
                                                            <Grid ColumnDefinitions="56,Auto" Visibility="{x:Bind RouteBackVisibility}">
                                                                <TextBlock Text="BACK"
                                                                           FontFamily="Consolas"
                                                                           Foreground="{x:Bind RouteBackBrush}"
                                                                           FontWeight="SemiBold"/>
                                                                <ItemsControl Grid.Column="1" ItemsSource="{x:Bind BackDisplayNodes}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <StackPanel Orientation="Horizontal"/>
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="pages:RouteDisplayNode">
                                                                            <Button Width="185"
                                                                                    Margin="0,0,10,0"
                                                                                    Padding="0"
                                                                                    Background="Transparent"
                                                                                    BorderThickness="0"
                                                                                    HorizontalContentAlignment="Left"
                                                                                    Click="TraceRouteNodeInfo_Click"
                                                                                    Tag="{x:Bind}">
                                                                                <TextBlock Text="{x:Bind DisplayName}"
                                                                                           FontFamily="Consolas"
                                                                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                                                           TextTrimming="CharacterEllipsis"
                                                                                           ToolTipService.ToolTip="{x:Bind TooltipText}"/>
                                                                            </Button>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </Grid>
                                                            <Grid ColumnDefinitions="56,Auto" Visibility="{x:Bind RouteBackDetailVisibility}">
                                                                <TextBlock Text=" "
                                                                           FontFamily="Consolas"/>
                                                                <ItemsControl Grid.Column="1" ItemsSource="{x:Bind BackDisplaySegments}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <StackPanel Orientation="Horizontal"/>
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="pages:RouteDisplaySegment">
                                                                            <StackPanel Width="185"
                                                                                        Margin="0,0,10,0"
                                                                                        Orientation="Horizontal"
                                                                                        Spacing="10"
                                                                                        ToolTipService.ToolTip="{x:Bind TooltipText}">
                                                                                <TextBlock Text="{x:Bind DistanceText}"
                                                                                           FontFamily="Consolas"
                                                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                                           TextTrimming="CharacterEllipsis"/>
                                                                                <TextBlock Text="{x:Bind SnrText}"
                                                                                           FontFamily="Consolas"
                                                                                           Foreground="{x:Bind SnrBrush}"
                                                                                           TextTrimming="CharacterEllipsis"/>
                                                                            </StackPanel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </Grid>
                                                    </StackPanel>
                                                    <Button Content="View route in map"
                                                            HorizontalAlignment="Left"
                                                            IsEnabled="{x:Bind CanViewRoute}"
                                                            Tag="{x:Bind}"
                                                            Click="TraceRouteEntryViewMap_Click"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TextBlock Text="No log entries yet."
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Opacity="0.7"
                                           Visibility="{x:Bind TraceRouteEmptyVisibility, Mode=OneWay}"/>
                                <controls:TeachingTip x:Name="TraceRouteDetailsTip"
                                                      PreferredPlacement="Top"
                                                      IsLightDismissEnabled="True"
                                                      Title="{x:Bind TraceRouteDetailTitle, Mode=OneWay}">
                                    <StackPanel Spacing="8" MaxWidth="980">
                                        <TextBlock Text="{x:Bind TraceRouteDetailHeader, Mode=OneWay}"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Disabled"
                                                      HorizontalScrollMode="Enabled"
                                                      VerticalScrollMode="Disabled"
                                                      ZoomMode="Disabled">
                                            <TextBlock Text="{x:Bind TraceRouteDetailRoute, Mode=OneWay}"
                                                       TextWrapping="NoWrap"
                                                       FontFamily="Consolas"/>
                                        </ScrollViewer>
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Disabled"
                                                      HorizontalScrollMode="Enabled"
                                                      VerticalScrollMode="Disabled"
                                                      ZoomMode="Disabled"
                                                      Visibility="{x:Bind TraceRouteDetailRouteBackVisibility, Mode=OneWay}">
                                            <TextBlock Text="{x:Bind TraceRouteDetailRouteBack, Mode=OneWay}"
                                                       TextWrapping="NoWrap"
                                                       FontFamily="Consolas"/>
                                        </ScrollViewer>
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Disabled"
                                                      HorizontalScrollMode="Enabled"
                                                      VerticalScrollMode="Disabled"
                                                      ZoomMode="Disabled"
                                                      Visibility="{x:Bind TraceRouteDetailMetricsVisibility, Mode=OneWay}">
                                            <TextBlock Text="{x:Bind TraceRouteDetailMetrics, Mode=OneWay}"
                                                       TextWrapping="NoWrap"
                                                       FontFamily="Consolas"/>
                                        </ScrollViewer>
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Disabled"
                                                      HorizontalScrollMode="Enabled"
                                                      VerticalScrollMode="Disabled"
                                                      ZoomMode="Disabled"
                                                      Visibility="{x:Bind TraceRouteDetailBackMetricsVisibility, Mode=OneWay}">
                                            <TextBlock Text="{x:Bind TraceRouteDetailBackMetrics, Mode=OneWay}"
                                                       TextWrapping="NoWrap"
                                                       FontFamily="Consolas"/>
                                        </ScrollViewer>
                                        <Button Content="View route in map"
                                                Click="TraceRouteViewMap_Click"
                                                IsEnabled="{x:Bind CanViewTraceRouteMap, Mode=OneWay}"/>
                                    </StackPanel>
                                </controls:TeachingTip>
                            </Grid>
                        </Grid>
                    </controls:TabViewItem>

                    <controls:TabViewItem x:Name="EnvironmentMetricsTabItem" IsClosable="False">
                        <controls:TabViewItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:Name="EnvironmentMetricsTabHeaderText" Text="Environment Metrics" Style="{StaticResource PrimaryTabHeaderTextStyle}"/>
                                <Ellipse Width="8" Height="8" Fill="#4FC3F7" VerticalAlignment="Center"
                                         Visibility="{x:Bind EnvironmentMetricsTabIndicatorVisibility, Mode=OneWay}"/>
                            </StackPanel>
                        </controls:TabViewItem.Header>
                        <Grid RowDefinitions="Auto,*" Padding="12">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind EnvironmentMetricsCountText, Mode=OneWay}" FontWeight="SemiBold"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button Content="Show folder"
                                            Tag="EnvironmentMetrics"
                                            Click="ShowLogFolder_Click"
                                            IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                    <TextBlock Text="Delete older than (days):" VerticalAlignment="Center"/>
                                    <controls:NumberBox Width="96"
                                                        Value="{x:Bind PositionLogRetentionDaysValue, Mode=TwoWay}"
                                                        Minimum="1"
                                                        SpinButtonPlacementMode="Inline"/>
                                    <Button Content="Delete"
                                            Tag="EnvironmentMetrics"
                                            Click="DeleteLogOlder_Click"
                                            IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                    <Button Content="Delete all"
                                            Tag="EnvironmentMetrics"
                                            Click="DeleteLogAll_Click"
                                            IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                    <Button Content="Export..." IsEnabled="False"/>
                                </StackPanel>
                            </Grid>
                            <ListView Grid.Row="1"
                                      x:Name="EnvironmentMetricsLogList"
                                      ItemsSource="{Binding EnvironmentMetricSamples, ElementName=Root}"
                                      SelectionMode="Single"
                                      SelectionChanged="EnvironmentMetricsLogList_SelectionChanged"
                                      IsItemClickEnabled="True"
                                      ItemClick="EnvironmentMetricsLogList_ItemClick"
                                      Margin="0,8,0,0">
                                <ListView.Header>
                                    <StackPanel Spacing="8" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Ellipse Width="8" Height="8" Fill="#FF4FC3F7"/>
                                                <TextBlock Text="Temperature"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Ellipse Width="8" Height="8" Fill="#FF81C784"/>
                                                <TextBlock Text="Humidity"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Ellipse Width="8" Height="8" Fill="#FFFFB74D"/>
                                                <TextBlock Text="Pressure"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <localcontrols:EnvironmentMetricsGraph x:Name="EnvironmentMetricsGraph"
                                                                               Height="220"/>
                                    </StackPanel>
                                </ListView.Header>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="MinHeight" Value="22"/>
                                        <Setter Property="Padding" Value="2"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:EnvironmentMetricSample">
                                        <Grid ColumnDefinitions="190,150,170,170"
                                              ColumnSpacing="12"
                                              Padding="2">
                                            <TextBlock Text="{x:Bind TimestampText}" FontFamily="Consolas" FontSize="12"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind TemperatureDisplay}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       Foreground="#FF4FC3F7"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{x:Bind HumidityDisplay}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       Foreground="#FF81C784"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{x:Bind PressureDisplay}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       Foreground="#FFFFB74D"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </controls:TabViewItem>

                    <controls:TabViewItem x:Name="PowerMetricsTabItem"
                                          IsClosable="False"
                                          Visibility="{x:Bind PowerMetricsTabVisibility, Mode=OneWay}">
                        <controls:TabViewItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:Name="PowerMetricsTabHeaderText" Text="Power Metrics"/>
                                <Ellipse Width="8" Height="8" Fill="LimeGreen" VerticalAlignment="Center"
                                         Visibility="{x:Bind PowerMetricsTabIndicatorVisibility, Mode=OneWay}"/>
                            </StackPanel>
                        </controls:TabViewItem.Header>
                        <Grid RowDefinitions="Auto,*" Padding="12">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Button Content="Show folder"
                                        Tag="PowerMetrics"
                                        Click="ShowLogFolder_Click"
                                        IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                <TextBlock Text="Delete older than (days):" VerticalAlignment="Center"/>
                                <controls:NumberBox Width="96"
                                                    Value="{x:Bind PositionLogRetentionDaysValue, Mode=TwoWay}"
                                                    Minimum="1"
                                                    SpinButtonPlacementMode="Inline"/>
                                <Button Content="Delete"
                                        Tag="PowerMetrics"
                                        Click="DeleteLogOlder_Click"
                                        IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                <Button Content="Delete all"
                                        Tag="PowerMetrics"
                                        Click="DeleteLogAll_Click"
                                        IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                <Button Content="Export..." IsEnabled="False"/>
                            </StackPanel>
                            <TextBox Grid.Row="1"
                                     Text="{x:Bind PowerMetricsLogText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas"
                                     Padding="8"
                                     Margin="0,8,0,0"/>
                        </Grid>
                    </controls:TabViewItem>

                    <controls:TabViewItem x:Name="DetectionSensorTabItem"
                                          IsClosable="False"
                                          Visibility="{x:Bind DetectionSensorTabVisibility, Mode=OneWay}">
                        <controls:TabViewItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:Name="DetectionSensorTabHeaderText" Text="Detection Sensor Log"/>
                                <Ellipse Width="8" Height="8" Fill="LimeGreen" VerticalAlignment="Center"
                                         Visibility="{x:Bind DetectionSensorTabIndicatorVisibility, Mode=OneWay}"/>
                            </StackPanel>
                        </controls:TabViewItem.Header>
                        <Grid RowDefinitions="Auto,*" Padding="12">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Button Content="Show folder"
                                        Tag="DetectionSensor"
                                        Click="ShowLogFolder_Click"
                                        IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                <TextBlock Text="Delete older than (days):" VerticalAlignment="Center"/>
                                <controls:NumberBox Width="96"
                                                    Value="{x:Bind PositionLogRetentionDaysValue, Mode=TwoWay}"
                                                    Minimum="1"
                                                    SpinButtonPlacementMode="Inline"/>
                                <Button Content="Delete"
                                        Tag="DetectionSensor"
                                        Click="DeleteLogOlder_Click"
                                        IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                <Button Content="Delete all"
                                        Tag="DetectionSensor"
                                        Click="DeleteLogAll_Click"
                                        IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                <Button Content="Export..." IsEnabled="False"/>
                            </StackPanel>
                            <TextBox Grid.Row="1"
                                     Text="{x:Bind DetectionSensorLogText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas"
                                     Padding="8"
                                     Margin="0,8,0,0"/>
                        </Grid>
                    </controls:TabViewItem>

                    <controls:TabViewItem x:Name="MeshAppsTabItem" IsClosable="False">
                        <controls:TabViewItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:Name="MeshAppsTabHeaderText" Text="Mesh Apps Log"/>
                                <Ellipse Width="8" Height="8" Fill="LimeGreen" VerticalAlignment="Center"
                                         Visibility="{x:Bind MeshAppsTabIndicatorVisibility, Mode=OneWay}"/>
                            </StackPanel>
                        </controls:TabViewItem.Header>
                        <Grid RowDefinitions="Auto,*" Padding="12">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Button Content="Show folder"
                                        Tag="MeshApps"
                                        Click="ShowLogFolder_Click"
                                        IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                <TextBlock Text="Delete older than (days):" VerticalAlignment="Center"/>
                                <controls:NumberBox Width="96"
                                                    Value="{x:Bind PositionLogRetentionDaysValue, Mode=TwoWay}"
                                                    Minimum="1"
                                                    SpinButtonPlacementMode="Inline"/>
                                <Button Content="Delete"
                                        Tag="MeshApps"
                                        Click="DeleteLogOlder_Click"
                                        IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                <Button Content="Delete all"
                                        Tag="MeshApps"
                                        Click="DeleteLogAll_Click"
                                        IsEnabled="{x:Bind HasSelection, Mode=OneWay}"/>
                                <TextBlock Text="Neighbor Info, Store &amp; Forward, Range Test, Map Report, Remote Hardware and PAX packets"
                                           VerticalAlignment="Center"
                                           Opacity="0.75"/>
                            </StackPanel>
                            <TextBox Grid.Row="1"
                                     Text="{x:Bind MeshAppsLogText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas"
                                     Padding="8"
                                     Margin="0,8,0,0"/>
                        </Grid>
                    </controls:TabViewItem>
                </controls:TabView>
            </Border>

            <TextBlock Grid.Row="3"
                       x:Name="MapFallbackText"
                       Text="Map assets missing"
                       Visibility="Collapsed"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       FontSize="16"
                       Opacity="0.8"
                       Margin="0,8,0,0"/>
        </Grid>
    </Grid>
</Page>
