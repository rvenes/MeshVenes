<Page
    x:Class="MeshVenes.Pages.SettingsRadioSecurityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12" MaxWidth="900" HorizontalAlignment="Left">
            <TextBlock Text="Security" FontSize="22" FontWeight="SemiBold"/>
            <TextBlock x:Name="StatusText" Text="Loading..." Opacity="0.85"/>

            <TextBlock
                Text="Public key is generated from private key by the node firmware. Edit private key only, then save and reload to see updated public key."
                TextWrapping="Wrap"
                Opacity="0.75"/>

            <Grid ColumnDefinitions="220,*" RowSpacing="8" ColumnSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Public key (base64)"/>
                <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBox x:Name="PublicKeyBox" IsReadOnly="True" TextWrapping="NoWrap"/>
                    <Button Grid.Column="1" Content="Copy" Click="CopyPublicKey_Click"/>
                </Grid>

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Private key (base64)"/>
                <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <TextBox x:Name="PrivateKeyBox" TextWrapping="NoWrap"/>
                    <Button Grid.Column="1" Content="Generate" Click="GeneratePrivateKey_Click"/>
                    <Button Grid.Column="2" Content="Clear" Click="ClearPrivateKey_Click"/>
                </Grid>

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Admin key 1 (base64)"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="AdminKey1Box"/>

                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Admin key 2 (base64)"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="AdminKey2Box"/>

                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Admin key 3 (base64)"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="AdminKey3Box"/>

                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Managed"/>
                <ToggleSwitch Grid.Row="5" Grid.Column="1" x:Name="IsManagedToggle"/>

                <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="Serial enabled"/>
                <ToggleSwitch Grid.Row="6" Grid.Column="1" x:Name="SerialEnabledToggle"/>

                <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Text="Debug log API enabled"/>
                <ToggleSwitch Grid.Row="7" Grid.Column="1" x:Name="DebugLogApiToggle"/>

                <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Text="Legacy admin channel enabled"/>
                <ToggleSwitch Grid.Row="8" Grid.Column="1" x:Name="AdminChannelToggle"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Reload" Click="Reload_Click"/>
                <Button Content="Save" Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
