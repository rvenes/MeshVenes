<Page
    x:Class="MeshVenes.Pages.MessagesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MeshVenes.Pages"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">

	    <Grid Padding="12">
	        <Grid.ColumnDefinitions>
	            <ColumnDefinition Width="360"/>
	            <ColumnDefinition Width="12"/>
	            <ColumnDefinition Width="*"/>
	        </Grid.ColumnDefinitions>

	        <!-- LEFT: chat/node list -->
	        <Grid Grid.Column="0" RowDefinitions="Auto,6,Auto,6,Auto,6,*">
	            <TextBlock Text="Chats" FontSize="22" FontWeight="SemiBold" />

            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Opacity="0.85" VerticalAlignment="Center">
                <Button Content="Sort / Filter">
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedLeft">
                            <ScrollViewer MaxHeight="420" Width="280">
                                <StackPanel Padding="12" Spacing="10">
                                    <TextBlock Text="Sort by" FontWeight="SemiBold"/>
                                    <RadioButton Content="Alphabetical"
                                                 GroupName="MessagesSortMode"
                                                 Tag="Alphabetical"
                                                 IsChecked="{x:Bind IsSortByAlphabetical, Mode=OneWay}"
                                                 Checked="SortModeRadio_Checked"/>
                                    <RadioButton Content="Hops away"
                                                 GroupName="MessagesSortMode"
                                                 Tag="HopsAway"
                                                 IsChecked="{x:Bind IsSortByHopsAway, Mode=OneWay}"
                                                 Checked="SortModeRadio_Checked"/>
                                    <RadioButton Content="Last heard"
                                                 GroupName="MessagesSortMode"
                                                 Tag="LastHeard"
                                                 IsChecked="{x:Bind IsSortByLastHeard, Mode=OneWay}"
                                                 Checked="SortModeRadio_Checked"/>
                                    <RadioButton Content="Favorites"
                                                 GroupName="MessagesSortMode"
                                                 Tag="FavoritesFirst"
                                                 IsChecked="{x:Bind IsSortByFavorites, Mode=OneWay}"
                                                 Checked="SortModeRadio_Checked"/>
                                    <RadioButton Content="My Nodes"
                                                 GroupName="MessagesSortMode"
                                                 Tag="MyNodes"
                                                 IsChecked="{x:Bind IsSortByMyNodes, Mode=OneWay}"
                                                 Checked="SortModeRadio_Checked"/>

                                    <TextBlock Text="Order" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                    <RadioButton Content="Ascending"
                                                 GroupName="MessagesSortDirection"
                                                 Tag="Ascending"
                                                 IsChecked="{x:Bind IsSortAscending, Mode=OneWay}"
                                                 Checked="SortDirectionRadio_Checked"/>
                                    <RadioButton Content="Descending"
                                                 GroupName="MessagesSortDirection"
                                                 Tag="Descending"
                                                 IsChecked="{x:Bind IsSortDescending, Mode=OneWay}"
                                                 Checked="SortDirectionRadio_Checked"/>

                                    <TextBlock Text="Filters" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                    <CheckBox Content="Hide inactive"
                                              Tag="HideInactive"
                                              IsChecked="{x:Bind IsHideInactiveEnabled, Mode=OneWay}"
                                              Click="FilterOption_Click"/>
                                    <CheckBox Content="My Nodes"
                                              Tag="MyNodesOnly"
                                              IsChecked="{x:Bind IsMyNodesFilterEnabled, Mode=OneWay}"
                                              Click="FilterOption_Click"/>
                                    <CheckBox Content="Favorites"
                                              Tag="FavoritesOnly"
                                              IsChecked="{x:Bind IsFavoritesFilterEnabled, Mode=OneWay}"
                                              Click="FilterOption_Click"/>
                                    <CheckBox Content="Via LoRa"
                                              Tag="IncludeLoRa"
                                              IsChecked="{x:Bind IsLoRaFilterEnabled, Mode=OneWay}"
                                              Click="FilterOption_Click"/>
                                    <CheckBox Content="Via MQTT"
                                              Tag="IncludeMqtt"
                                              IsChecked="{x:Bind IsMqttFilterEnabled, Mode=OneWay}"
                                              Click="FilterOption_Click"/>
                                    <Button Content="Clear filters"
                                            HorizontalAlignment="Left"
                                            Margin="0,6,0,0"
                                            Visibility="{x:Bind ActiveChatFiltersVisibility, Mode=OneWay}"
                                            Click="ClearFilters_Click"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <TextBlock Text="{x:Bind ActiveChatFiltersText, Mode=OneWay}"
                           Visibility="{x:Bind ActiveChatFiltersVisibility, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="220"/>
            </StackPanel>

	            <TextBox Grid.Row="4"
	                     x:Name="ChatSearchBox"
	                     PlaceholderText="Search (name / id)"
	                     TextChanged="ChatSearchBox_TextChanged"/>

            <ListView Grid.Row="6"
                      x:Name="ChatList"
                      ItemsSource="{x:Bind ChatsView, Mode=OneWay}"
                      SelectionMode="Single"
                      SelectionChanged="ChatList_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:ChatListItemVm">
                        <Grid Padding="6" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="4" Margin="0,0,8,0">
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="LimeGreen"
                                         VerticalAlignment="Center"
                                         Visibility="{x:Bind LogIndicatorVisible}"/>
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="LimeGreen"
                                         VerticalAlignment="Center"
                                         Visibility="{x:Bind UnreadVisible}"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="{x:Bind Title}" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{x:Bind ShortId}" Opacity="0.7" VerticalAlignment="Center"/>

                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8" Opacity="0.8" Margin="0,2,0,0">
                                <TextBlock Text="{x:Bind LastHeard}" />
                                <TextBlock Text="Link:"/>
                                <TextBlock Text="{x:Bind Transport}" Foreground="{x:Bind TransportForeground}" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind HopsBadgeText}" />
                            </StackPanel>

                            <Button Grid.Row="1"
                                    Grid.Column="2"
                                    Content="{x:Bind FavoriteGlyph, Mode=OneWay}"
                                    Foreground="{x:Bind FavoriteBrush, Mode=OneWay}"
                                    Visibility="{x:Bind FavoriteVisibility, Mode=OneWay}"
                                    Click="ChatFavoriteButton_Click"
                                    FontSize="16"
                                    Padding="4,0"
                                    MinWidth="26"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    ToolTipService.ToolTip="Favorite node (stored on connected node)"/>

                            <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8" Opacity="0.75" Margin="0,2,0,0">
                                <TextBlock Text="🗒"/>
                                <TextBlock Text="📍" Visibility="{x:Bind PositionIconVisibility}"/>
                                <TextBlock Text="{x:Bind BatteryBadgeText}"
                                           Foreground="{x:Bind BatteryBadgeForeground}"
                                           Visibility="{x:Bind BatteryBadgeVisibility}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

	        <!-- RIGHT: messages -->
	        <Grid Grid.Column="2" RowDefinitions="Auto,8,Auto,8,*,12,Auto">
	            <!-- Header -->
	            <TextBlock Text="{x:Bind ActiveChatTitle, Mode=OneWay}" FontSize="30" FontWeight="SemiBold" />

                <!-- Log controls -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center">
                    <Button Content="Show folder"
                            Click="ShowMessageLogFolder_Click"
                            IsEnabled="{x:Bind HasAnyChatSelection, Mode=OneWay}"/>
                    <TextBlock Text="Delete older than (days):" VerticalAlignment="Center"/>
                    <controls:NumberBox x:Name="MessageLogRetentionBox"
                                        Width="96"
                                        Minimum="1"
                                        SpinButtonPlacementMode="Inline"
                                        Value="{x:Bind MessageLogRetentionDaysValue, Mode=TwoWay}"/>
                    <Button Content="Delete"
                            Click="DeleteMessageLogOlder_Click"
                            IsEnabled="{x:Bind HasAnyChatSelection, Mode=OneWay}"/>
                    <Button Content="Delete all"
                            Click="DeleteMessageLogAll_Click"
                            IsEnabled="{x:Bind HasAnyChatSelection, Mode=OneWay}"/>
                    <Button Content="Open node"
                            Click="OpenNodeFromDm_Click"
                            IsEnabled="{x:Bind CanOpenNodeFromDm, Mode=OneWay}"
                            Visibility="{x:Bind OpenNodeFromDmVisibility, Mode=OneWay}"/>
                </StackPanel>

            <!-- Messages -->
            <Grid Grid.Row="4">
                <ListView x:Name="MessagesList"
                          ItemsSource="{x:Bind SelectedChatMessages, Mode=OneWay}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:MessageVm">
                            <Grid Padding="10"
                                  Visibility="{x:Bind RowVisibility}">
                                <Grid Visibility="{x:Bind DividerVisibility}"
                                      ColumnDefinitions="*,Auto,*"
                                      VerticalAlignment="Center"
                                      Margin="0,6,0,6">
                                    <Rectangle Height="1"
                                               Fill="#FFDD3B3B"
                                               Opacity="0.9"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="Chat history"
                                               Foreground="#FFDD3B3B"
                                               Opacity="0.9"
                                               FontWeight="SemiBold"
                                               Margin="10,0,10,0"/>
                                    <Rectangle Grid.Column="2"
                                               Height="1"
                                               Fill="#FFDD3B3B"
                                               Opacity="0.9"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <StackPanel Spacing="4"
                                            Visibility="{x:Bind MessageVisibility}">
	                                    <StackPanel Orientation="Horizontal" Spacing="12">
	                                        <TextBlock Text="{x:Bind Header}" FontWeight="SemiBold"/>
	                                        <TextBlock Text="{x:Bind When}" Opacity="0.7"/>
	                                    </StackPanel>

	                                    <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="6">
	                                        <!-- ✓ (heard) -->
	                                        <FontIcon Glyph="&#xE73E;"
	                                                  Foreground="Green"
	                                                  FontFamily="Segoe MDL2 Assets"
	                                                  Visibility="{x:Bind HeardVisible}" />

	                                        <!-- ✓✓ (delivered) -->
	                                        <FontIcon Glyph="&#xE73E;"
                                                      Grid.Column="1"
	                                                  Foreground="Green"
	                                                  FontFamily="Segoe MDL2 Assets"
	                                                  Visibility="{x:Bind DeliveredVisible}" />

                                            <RichTextBlock IsTextSelectionEnabled="True"
                                                           Grid.Column="2"
                                                           TextWrapping="Wrap"
                                                           DataContextChanged="MessageText_DataContextChanged"
                                                           Tag="{x:Bind Text, Mode=OneWay}">
                                                <RichTextBlock.ContextFlyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem Text="Copy" Click="CopyMessageText_Click"/>
                                                    </MenuFlyout>
                                                </RichTextBlock.ContextFlyout>
                                            </RichTextBlock>
                                        </Grid>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Button x:Name="NewMessagesButton"
                        Content="New messages below"
                        Visibility="Collapsed"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,14,14"
                        Click="NewMessagesButton_Click"/>
            </Grid>

	            <!-- Composer -->
	            <Grid Grid.Row="6">
	                <Grid.ColumnDefinitions>
	                    <ColumnDefinition Width="*"/>
	                    <ColumnDefinition Width="12"/>
	                    <ColumnDefinition Width="96"/>
	                    <ColumnDefinition Width="8"/>
	                    <ColumnDefinition Width="46"/>
	                    <ColumnDefinition Width="8"/>
	                    <ColumnDefinition Width="190"/>
	                </Grid.ColumnDefinitions>

	                <TextBox x:Name="InputBox"
	                         PlaceholderText="Type a message..."
	                         AcceptsReturn="False"
	                         TextChanged="InputBox_TextChanged"
	                         KeyDown="InputBox_KeyDown"/>

	                <Button Grid.Column="2"
                            x:Name="SendButton"
	                        Content="Send"
	                        Click="Send_Click"/>

                    <Button Grid.Column="4"
                            Content="😊"
                            ToolTipService.ToolTip="Insert emoji">
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="😀" Click="InsertEmojiMenuItem_Click"/>
                                <MenuFlyoutItem Text="😂" Click="InsertEmojiMenuItem_Click"/>
                                <MenuFlyoutItem Text="🙂" Click="InsertEmojiMenuItem_Click"/>
                                <MenuFlyoutItem Text="😍" Click="InsertEmojiMenuItem_Click"/>
                                <MenuFlyoutItem Text="👍" Click="InsertEmojiMenuItem_Click"/>
                                <MenuFlyoutItem Text="🙏" Click="InsertEmojiMenuItem_Click"/>
                                <MenuFlyoutItem Text="❤️" Click="InsertEmojiMenuItem_Click"/>
                                <MenuFlyoutItem Text="🔥" Click="InsertEmojiMenuItem_Click"/>
                                <MenuFlyoutItem Text="🎉" Click="InsertEmojiMenuItem_Click"/>
                                <MenuFlyoutItem Text="🇳🇴" Click="InsertEmojiMenuItem_Click"/>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <TextBlock Grid.Column="6"
                               x:Name="MessageLengthText"
                               Text="0/200 bytes"
                               Opacity="0.75"
                               FontFamily="Consolas"
                               TextAlignment="Right"
                               VerticalAlignment="Center"/>
	            </Grid>
	        </Grid>
	    </Grid>
</Page>
