<Page
    x:Class="MeshVenes.Pages.AboutPage"
    NavigationCacheMode="Required"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="12" MaxWidth="900">
            <TextBlock Text="About" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="{x:Bind VersionText, Mode=OneTime}" Opacity="0.9"/>
            <TextBlock x:Name="UpdateStatusText" Text="Update status: checking for updates..." Opacity="0.9" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Check for updates" Click="CheckForUpdates_Click"/>
                <Button x:Name="UpdateInstallButton"
                        Content="Download and install"
                        Style="{ThemeResource AccentButtonStyle}"
                        Visibility="Collapsed"
                        Click="UpdateInstall_Click"/>
                <HyperlinkButton x:Name="UpdateLinkButton"
                                 Content="Open latest release"
                                 Visibility="Collapsed"/>
            </StackPanel>
            <ProgressBar x:Name="UpdateProgressBar"
                         Minimum="0"
                         Maximum="1"
                         Visibility="Collapsed"/>

            <TextBlock TextWrapping="Wrap">
                MeshVenes is an unofficial desktop app for connecting to Meshtastic radios and working with messages and nodes.
            </TextBlock>

            <TextBlock Text="How to use" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap">
                Use Connect to attach to a device over Serial (USB), TCP/IP, or Bluetooth LE, then go to Messages and Nodes to interact with your network.
                Settings contains app options.
            </TextBlock>

            <TextBlock Text="Licensing" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap">
                MeshVenes is free and open-source software licensed under GNU GPL 3.0.
            </TextBlock>

            <TextBlock Text="Donations (Optional)" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap">
                The program is free. Donations are optional and help improve features, stability, testing, and long-term support.
            </TextBlock>
            <HyperlinkButton Content="Donate via PayPal (paypal.me/rvenes)"
                             NavigateUri="https://paypal.me/rvenes"/>
        </StackPanel>
    </ScrollViewer>
</Page>
